<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Growlity.ai — ESG Growth Intelligence</title>
<!-- AOS CSS -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<style>
/* ============================================================
   RESET + TOKENS
   ============================================================ */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  /* GROWLITY THEME (LIGHT MODE) */
  --forest:   #ffffff;        /* Main Background */
  --panel:    #f8fafc;        /* Secondary Background */
  --jade:     #4186f3;        /* Primary Brand Blue */
  --secondary:#3eac5c;        /* Secondary Brand Green */
  --bone:     #0f172a;        /* Main Text Color */
  --ink:      #ffffff;        /* Inverted Text Color (White) */
  --white:    #0f172a;        /* Titles and contrast elements (Dark) */
  --pure-white: #ffffff;      /* Actual White */
  --line:     rgba(65, 134, 243, 0.15); /* Brand Blue borders */
  --text-dim: #475569;        /* Muted Text */
  --text-dim2:#94a3b8;        /* Very Muted Text */

  --font-display: "Helvetica Neue", Helvetica, Arial, sans-serif;
  --font-body: "Helvetica Neue", Helvetica, Arial, sans-serif;

  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 18px;
  --container: 1100px;
}

html { scroll-behavior: smooth; }
body { font-family: var(--font-body); background: var(--forest); color: var(--bone); }
a { color: inherit; }
ul { list-style: none; }
.con { max-width: var(--container); margin: 0 auto; }

/* ============================================================
   REUSABLE PRIMITIVES
   ============================================================ */
.card {
  background: var(--pure-white);
  border: 1px solid var(--line);
  border-radius: var(--radius-md);
  box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
}
.card:hover { border-color: var(--jade); box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.08); }

.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 12px 26px; border-radius: var(--radius-sm);
  font-size: 14px; font-weight: 700; text-decoration: none;
  transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
}
.btn-primary { background: var(--jade); color: var(--ink); }
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(65, 134, 243,.25); }
.btn-secondary {
  background: var(--secondary); color: var(--pure-white); font-weight: 500; border: none;
}
.btn-secondary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(62, 172, 92, .25); }

.eyebrow {
  font-size: 11px; letter-spacing: 1.2px; text-transform: uppercase;
  font-weight: 600; color: var(--jade); margin-bottom: 10px;
}
.section-title {
  font-family: var(--font-display); font-weight: 800;
  font-size: clamp(28px, 3vw, 42px); line-height: 1.15; letter-spacing: -1px;
  color: var(--white); max-width: 640px; margin-bottom: 14px;
}
.section-sub {
  font-size: 15px; line-height: 1.7; color: var(--text-dim);
  max-width: 480px; margin-bottom: 48px;
}
.center { text-align: center; }
.center .section-title, .center .section-sub { max-width: 600px; margin-left: auto; margin-right: auto; }

.section { padding: 88px 32px; }
.section--light { background: #f1f5f9; color: var(--bone); }
.section--light .eyebrow { color: var(--secondary); }
.section--light .section-title { color: var(--bone); }
.section--light .section-sub { color: var(--text-dim); }
.section--panel { background: var(--panel); }

@media (max-width: 860px) { .section { padding: 56px 20px; } }

/* ============================================================
   NAV
   ============================================================ */
nav {
  position: fixed; top: 0; width: 100%; z-index: 200; height: 62px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px;
  background: rgba(255,255,255,.88); backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--line);
}
.logo {
  display: flex; align-items: center; gap: 9px;
  font-family: var(--font-display); font-weight: 700; font-size: 18px;
  letter-spacing: -.3px; text-decoration: none; color: var(--white);
}
.logo em { font-style: normal; color: var(--jade); }
.logo-mark {
  width: 28px; height: 28px; border-radius: 7px; background: var(--jade);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.logo-mark svg { width: 15px; height: 15px; }

.nav-links { display: flex; align-items: center; gap: 28px; }
.nav-links a { font-size: 13.5px; font-weight: 500; color: var(--text-dim); text-decoration: none; }
.nav-links a:hover { color: var(--white); }

.nav-end { display: flex; align-items: center; gap: 8px; }
.n-signin { font-size: 13.5px; color: var(--text-dim); text-decoration: none; padding: 7px 14px; }
.n-signin:hover { color: var(--white); }

@media (max-width: 860px) { nav { padding: 0 20px; } .nav-links { display: none; } }

/* ============================================================
   HERO
   ============================================================ */
.hero {
  min-height: 92vh; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 110px 24px 56px; text-align: center; position: relative;
}
.hero::before {
  content: ''; position: absolute; top: -100px; left: 50%; transform: translateX(-50%);
  width: 800px; height: 480px;
  background: radial-gradient(ellipse at center, rgba(30,224,127,.12) 0%, transparent 65%);
  pointer-events: none;
}

.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 5px 14px; border-radius: 99px; border: 1px solid var(--line);
  background: rgba(30,224,127,.06);
  font-size: 11.5px; font-weight: 600; letter-spacing: .8px; text-transform: uppercase;
  color: var(--jade); margin-bottom: 24px; position: relative;
}

h1 {
  font-family: var(--font-display); font-weight: 800;
  font-size: clamp(32px, 4.2vw, 56px); line-height: 1.12; letter-spacing: -1.3px;
  color: var(--white); max-width: 780px; margin-bottom: 18px; position: relative;
}
h1 .hl { color: var(--secondary); }

.hero-sub {
  font-size: 16px; line-height: 1.7; color: var(--text-dim);
  max-width: 500px; margin-bottom: 32px; position: relative;
}

.hero-btns { display: flex; gap: 12px; margin-bottom: 44px; position: relative; }

.hero-trust {
  display: flex; gap: 22px; flex-wrap: wrap; justify-content: center;
  font-size: 12.5px; color: var(--text-dim2); margin-bottom: 52px; position: relative;
}
.hero-trust span { display: flex; align-items: center; gap: 6px; }
.hero-trust span::before { content: '✓'; color: var(--jade); font-size: 12px; }

@media (max-width: 860px) {
  .hero-btns { flex-direction: column; width: 100%; }
  .btn { width: 100%; }
}

/* ----- Product preview ----- */
.screen-wrap { width: 100%; max-width: 1020px; position: relative; }
.browser {
  border-radius: 12px; overflow: hidden; border: 1px solid var(--line);
  box-shadow: 0 30px 80px rgba(0,0,0,.55);
}
.browser-bar {
  background: var(--panel); height: 38px; display: flex; align-items: center;
  padding: 0 14px; gap: 7px; border-bottom: 1px solid var(--line);
}
.bt { width: 10px; height: 10px; border-radius: 50%; }
.bt-r { background: #ff5f57; } .bt-y { background: #febc2e; } .bt-g { background: #28c840; }
.b-url {
  flex: 1; margin: 0 12px; background: rgba(0,0,0,.05); border-radius: 5px;
  height: 21px; display: flex; align-items: center; padding: 0 10px;
  font-size: 11px; color: var(--text-dim); font-family: monospace;
}
.ai-badge {
  font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 5px;
  background: rgba(65,134,243,.12); color: var(--jade); border: 1px solid var(--line);
}

.dash {
  display: grid; grid-template-columns: 190px 1fr; grid-template-rows: 42px 1fr;
  background: var(--pure-white); height: 480px;
}
.db-side {
  grid-row: 1 / 3; background: var(--panel); border-right: 1px solid var(--line);
  padding: 16px 10px; display: flex; flex-direction: column; gap: 2px;
}
.db-brand {
  font-family: var(--font-display); font-weight: 800; font-size: 13px;
  color: var(--jade); margin-bottom: 18px; padding: 0 6px;
}
.nav-i {
  display: flex; align-items: center; gap: 9px; padding: 8px 10px;
  border-radius: 6px; font-size: 12px; color: var(--text-dim);
}
.nav-i.on { background: rgba(65,134,243,.1); color: var(--jade); }
.db-sep { height: 1px; background: var(--line); margin: 8px 0; }

.db-top {
  grid-column: 2; background: var(--pure-white); border-bottom: 1px solid var(--line);
  display: flex; align-items: center; justify-content: space-between; padding: 0 18px;
}
.db-top h3 { font-family: var(--font-display); font-weight: 700; font-size: 14px; color: var(--bone); }
.db-pills { display: flex; gap: 6px; }
.dp { padding: 4px 11px; border-radius: 20px; font-size: 11px; font-weight: 500;
      background: rgba(0,0,0,.04); color: var(--text-dim); }
.dp.on { background: rgba(65,134,243,.1); color: var(--jade); }

.db-main {
  grid-column: 2; padding: 14px 16px;
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
}
.kpi { padding: 13px; }
.kpi-lbl { font-size: 10px; color: var(--text-dim); letter-spacing: .5px; text-transform: uppercase; margin-bottom: 8px; }
.kpi-val { font-family: var(--font-display); font-weight: 800; font-size: 21px; color: var(--bone); }
.kpi-val .u { font-size: 11px; color: var(--text-dim2); margin-left: 3px; }
.kpi-d { font-size: 11px; font-weight: 600; color: var(--secondary); margin-top: 4px; }

.chart-wide { grid-column: 1 / 3; padding: 13px; }
.ct-title { font-size: 10px; font-weight: 600; color: var(--text-dim); text-transform: uppercase; margin-bottom: 12px; }
.bars { display: flex; align-items: flex-end; gap: 6px; height: 76px; }
.bar-c { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; }
.bar-f { width: 100%; border-radius: 3px 3px 0 0; background: var(--jade); }

.ring-card { padding: 13px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; }
.ring-wrap { position: relative; width: 68px; height: 68px; }
.ring-wrap svg { transform: rotate(-90deg); }
.ring-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.ring-num { font-family: var(--font-display); font-weight: 800; font-size: 17px; color: var(--secondary); }
.ring-sub { font-size: 8px; color: var(--text-dim2); }
.ring-lbl { font-size: 10px; color: var(--text-dim); text-align: center; }

.fw-card { grid-column: 4; padding: 13px; }
.fw-title { font-size: 10px; font-weight: 600; color: var(--text-dim); text-transform: uppercase; margin-bottom: 10px; }
.fw-badge {
  display: inline-block; padding: 3px 9px; border-radius: 5px; font-size: 10px;
  font-weight: 700; margin: 2px; background: rgba(65,134,243,.1); color: var(--jade);
}

@media (max-width: 860px) {
  .dash { height: 340px; }
  .db-main { grid-template-columns: 1fr 1fr; }
}

/* ============================================================
   LOGOS
   ============================================================ */
.logos-band {
  background: var(--pure-white); border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line); padding: 26px 32px;
}
.logos-lbl {
  text-align: center; font-size: 11px; letter-spacing: 1px; text-transform: uppercase;
  color: var(--text-dim); margin-bottom: 22px;
}
.logos-row { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 32px; }
.l-name { font-family: var(--font-display); font-weight: 700; font-size: 14px; color: var(--text-dim); }

/* ============================================================
   FEATURE GRID
   ============================================================ */
.feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.fc { padding: 26px 22px; }
.section--light .fc { background: var(--pure-white); border-color: rgba(0,0,0,.08); }
.fi {
  width: 40px; height: 40px; border-radius: 10px; background: rgba(65,134,243,.1);
  display: flex; align-items: center; justify-content: center; font-size: 19px; margin-bottom: 16px;
}
.section--light .fi { background: rgba(65,134,243,.1); }
.ft { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--bone); margin-bottom: 8px; }
.section--light .ft { color: var(--bone); }
.fd { font-size: 13.5px; line-height: 1.6; color: var(--text-dim); }
.section--light .fd { color: var(--text-dim); }
.fc-tag {
  display: inline-block; margin-top: 14px; font-size: 10.5px; font-weight: 600;
  padding: 3px 10px; border-radius: 5px; background: rgba(62, 172, 92, 0.1); color: var(--secondary);
}
.section--light .fc-tag { background: rgba(62, 172, 92, 0.1); color: var(--secondary); }

@media (max-width: 860px) { .feat-grid { grid-template-columns: 1fr; } }

/* ============================================================
   STEPS
   ============================================================ */
.steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 32px; position: relative; }
.steps::before {
  content: ''; position: absolute; top: 36px; left: 16.6%; right: 16.6%; height: 1px;
  background: linear-gradient(90deg, transparent, var(--line), transparent);
}
.step { text-align: center; padding: 0 14px; position: relative; }
.step-n {
  width: 72px; height: 72px; border-radius: 50%; border: 2px solid var(--line);
  background: rgba(30,224,127,.06); display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px; font-family: var(--font-display); font-weight: 800; font-size: 22px; color: var(--secondary);
}
.step-t { font-family: var(--font-display); font-weight: 700; font-size: 16px; margin-bottom: 10px; color: var(--ink); }
.step-d { font-size: 13.5px; line-height: 1.6; color: rgba(14,26,18,.55); }

@media (max-width: 860px) { .steps { grid-template-columns: 1fr; gap: 28px; } .steps::before { display: none; } }

/* ============================================================
   SPLIT SECTIONS
   ============================================================ */
.split { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
.split.flip { direction: rtl; }
.split.flip > * { direction: ltr; }
.split-vis { border-radius: 14px; overflow: hidden; border: 1px solid var(--line); box-shadow: 0 24px 64px rgba(0,0,0,.4); }
.section--light .split-vis { border-color: rgba(0,0,0,.1); box-shadow: 0 20px 48px rgba(0,0,0,.1); }

.tick-list { display: flex; flex-direction: column; gap: 12px; margin-top: 22px; }
.tick-list li { display: flex; gap: 11px; font-size: 14px; line-height: 1.6; color: var(--text-dim); }
.section--light .tick-list li { color: rgba(14,26,18,.6); }
.tick-list li::before {
  content: '✓'; flex-shrink: 0; width: 19px; height: 19px; margin-top: 1px;
  border-radius: 50%; background: rgba(62, 172, 92, 0.15); color: var(--secondary);
  font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center;
}

.mv, .mv-b { padding: 20px; }
.mv { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; }
.mv-b { background: var(--pure-white); border: 1px solid var(--line); border-radius: 12px; }
.mv-eyebrow { font-size: 10px; letter-spacing: .7px; text-transform: uppercase; font-weight: 600; margin-bottom: 12px; }
.mv .mv-eyebrow { color: var(--jade); }
.mv-b .mv-eyebrow { color: var(--jade); }

.mv-row { display: flex; gap: 10px; margin-bottom: 10px; }
.mv-pill { flex: 1; border-radius: 10px; padding: 12px; background: var(--pure-white); border: 1px solid var(--line); box-shadow: 0 2px 4px rgb(0 0 0 / 0.02); }
.mv-pill .v { font-family: var(--font-display); font-weight: 800; font-size: 19px; color: var(--secondary); }
.mv-pill .k { font-size: 10px; color: var(--text-dim); margin-top: 2px; text-transform: uppercase; }

.mini-bars { display: flex; align-items: flex-end; gap: 5px; height: 68px; padding: 0 2px; background: rgba(65,134,243,.05); border-radius: 7px; margin-top: 10px; }
.mb { flex: 1; border-radius: 3px 3px 0 0; background: var(--jade); }

.tag-row { margin-top: 10px; display: flex; gap: 8px; flex-wrap: wrap; }
.tag-chip { font-size: 9px; color: var(--jade); background: rgba(65,134,243,.1); padding: 3px 8px; border-radius: 4px; }

.ri {
  display: flex; align-items: center; justify-content: space-between;
  padding: 11px 13px; background: var(--pure-white); border-radius: 9px;
  margin-bottom: 7px; border: 1px solid var(--line);
}
.ri .rn { font-size: 12.5px; font-weight: 600; color: var(--bone); }
.ri .rs { font-size: 10.5px; color: var(--text-dim); margin-top: 1px; }
.rbadge { font-size: 10px; font-weight: 600; padding: 3px 9px; border-radius: 20px; }
.rb-g { background: #e0f2fe; color: #0284c7; }
.rb-progress { background: #fef3c7; color: #d97706; }

@media (max-width: 860px) { .split, .split.flip { grid-template-columns: 1fr; direction: ltr; gap: 28px; } }

/* ============================================================
   STATS
   ============================================================ */
.stats-wrap { background: var(--pure-white); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 52px 32px; }
.stats-grid { max-width: var(--container); margin: 0 auto; display: grid; grid-template-columns: repeat(4,1fr); }
.si { text-align: center; padding: 0 18px; border-right: 1px solid var(--line); }
.si:last-child { border-right: none; }
.si-n { font-family: var(--font-display); font-weight: 800; font-size: 40px; color: var(--secondary); letter-spacing: -1px; }
.si-l { font-size: 12.5px; color: var(--text-dim); line-height: 1.5; margin-top: 6px; }

@media (max-width: 860px) {
  .stats-grid { grid-template-columns: repeat(2,1fr); }
  .si { border-right: none; border-bottom: 1px solid var(--line); padding: 18px; }
}

/* ============================================================
   TESTIMONIALS
   ============================================================ */
.tg { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
.tc { padding: 24px; }
.t-stars { color: var(--secondary); font-size: 12px; margin-bottom: 12px; }
.t-q { font-size: 13.5px; line-height: 1.65; color: var(--text-dim); margin-bottom: 18px; }
.t-a { display: flex; align-items: center; gap: 11px; }
.t-av {
  width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
  font-family: var(--font-display); font-weight: 800; font-size: 13px;
  display: flex; align-items: center; justify-content: center; background: var(--jade); color: var(--ink);
}
.t-name { font-size: 13px; font-weight: 600; color: var(--white); }
.t-role { font-size: 11px; color: var(--text-dim2); margin-top: 1px; }

@media (max-width: 860px) { .tg { grid-template-columns: 1fr; } }

/* ============================================================
   PRICING
   ============================================================ */
.pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; max-width: 880px; margin: 0 auto; }
.pc { padding: 34px 30px; position: relative; }
.pc.featured { border-color: rgba(65,134,243,.4); background: rgba(65,134,243,.03); }
.pc.featured::before {
  content: 'MOST POPULAR'; position: absolute; top: 18px; right: 20px;
  font-size: 9px; font-weight: 700; letter-spacing: 1px; color: var(--pure-white);
  background: var(--jade); padding: 3px 10px; border-radius: 20px;
}
.pc-badge {
  font-size: 10px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase;
  color: var(--jade); background: rgba(65,134,243,.1); border: 1px solid var(--line);
  display: inline-block; padding: 4px 12px; border-radius: 20px; margin-bottom: 16px;
}
.pc-name { font-family: var(--font-display); font-weight: 800; font-size: 23px; color: var(--bone); margin-bottom: 8px; }
.pc-ideal { font-size: 13px; line-height: 1.6; color: var(--text-dim); margin-bottom: 26px; min-height: 40px; }
.pc-divider { height: 1px; background: var(--line); margin-bottom: 24px; }
.pc-features { display: flex; flex-direction: column; gap: 13px; margin-bottom: 28px; }
.pc-features li { display: flex; align-items: flex-start; gap: 10px; font-size: 13.5px; line-height: 1.55; color: var(--bone); }
.pc-features li.off { color: var(--text-dim2); }
.pc-features .note { display: block; font-size: 11.5px; color: var(--text-dim); padding-left: 28px; }
.chk {
  width: 17px; height: 17px; border-radius: 50%; flex-shrink: 0; margin-top: 1px;
  background: rgba(62, 172, 92, 0.15); color: var(--secondary);
  display: flex; align-items: center; justify-content: center; font-size: 10px;
}
.chk.na { background: rgba(0,0,0,.05); color: rgba(0,0,0,.2); }
.pc-inherit {
  font-size: 11.5px; font-weight: 600; color: var(--jade);
  background: rgba(65,134,243,.05); border: 1px solid var(--line);
  border-radius: 8px; padding: 9px 14px; margin-bottom: 16px;
}
.pc-purpose { background: rgba(0,0,0,.02); border-radius: 10px; padding: 16px; margin-bottom: 26px; border: 1px solid var(--line); }
.pc-purpose-label { font-size: 9.5px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; color: var(--jade); margin-bottom: 6px; }
.pc-purpose p { font-size: 13px; line-height: 1.6; color: var(--text-dim); }
.pc-cta { display: block; text-align: center; }
.pc-cta.outline { border: 1px solid var(--line); color: var(--jade); background: none; }
.pc-cta.outline:hover { background: rgba(65,134,243,.05); }

@media (max-width: 860px) { .pricing-grid { grid-template-columns: 1fr; } }

/* ============================================================
   CONTACT FORM
   ============================================================ */
.contact-wrap { max-width: 520px; margin: 0 auto; padding: 40px; }
.cf-row { margin-bottom: 18px; }
.cf-label { display: block; font-size: 12px; font-weight: 600; color: var(--text-dim); margin-bottom: 8px; }
.cf-input {
  width: 100%; padding: 12px 16px; background: var(--pure-white);
  border: 1px solid var(--line); border-radius: 9px; color: var(--bone);
