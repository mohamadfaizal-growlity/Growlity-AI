<!-- AOS JS -->
<script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

<script is:inline>
  // Initialize AOS Animation Library
  // @ts-ignore
  if (window.AOS) {
      // @ts-ignore
      window.AOS.init({
          duration: 800,   // The animation takes 800ms (0.8 seconds) to complete
          once: true,      // The animation only happens once when scrolling down
          offset: 50,      // The animation triggers when the element is 50px away from the viewport
      });
  }

  // Number Counter Logic
  const stats = document.querySelectorAll('.stat-num');
  if (stats.length > 0) {
      const statsObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  // @ts-ignore
                  const el = entry.target;
                  const targetAttr = el.getAttribute('data-target');
                  if (targetAttr) {
                      const target = parseFloat(targetAttr);
                      let count = 0;
                      const duration = 2000;
                      const increment = target / (duration / 16);
                      
                      const updateCount = () => {
                          count += increment;
                          if (count < target) {
                              el.innerHTML = target % 1 === 0 ? Math.ceil(count).toString() : count.toFixed(1);
                              requestAnimationFrame(updateCount);
                          } else {
                              el.innerHTML = target.toString();
                          }
                      };
                      updateCount();
                  }
                  statsObserver.unobserve(el);
              }
          });
      }, { threshold: 0.5 });
      stats.forEach(stat => statsObserver.observe(stat));
  }

  function openModal() {
    document.getElementById('notify-modal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    document.getElementById('notify-modal').classList.remove('open');
    document.body.style.overflow = '';
  }
  document.getElementById('notify-modal').addEventListener('click', function (e) {
    if (e.target === this) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });

  function handleModalSubmit(e) {
    e.preventDefault();
    document.getElementById('modal-form').style.display = 'none';
    document.getElementById('modal-success').style.display = 'block';
  }

  // Cross-origin trigger from growlity.com
  window.addEventListener('message', function (event) {
    // In production, restrict origin: if (event.origin !== 'https://growlity.com') return;
    if (event.data === 'open-contact' || event.data === 'notify-me') openModal();
    if (event.data === 'open-pricing') document.getElementById('pricing').scrollIntoView({ behavior: 'smooth' });
  });

  if (window.location.hash === '#notify') {
    window.addEventListener('load', openModal);
  }
</script>

