---
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();
const entries = await prisma.contactEntry.findMany({
  orderBy: {
    createdAt: 'desc'
  }
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Growlity</title>
  <style>
    body { font-family: "Helvetica Neue", Helvetica, sans-serif; background: #f8fafc; color: #0f172a; margin: 0; padding: 40px; }
    h1 { margin-bottom: 32px; font-weight: 800; }
    table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); }
    th, td { padding: 16px 20px; text-align: left; border-bottom: 1px solid #e2e8f0; }
    th { background: #f1f5f9; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; color: #475569; font-weight: 600; }
    td { font-size: 14.5px; }
    tr:last-child td { border-bottom: none; }
    tr:hover { background: #f8fafc; }
    .badge { background: #e0f2fe; color: #0284c7; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; }
  </style>
</head>
<body>
  <h1>Admin Dashboard - Leads</h1>
  
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Date</th>
        <th>Name</th>
        <th>Email</th>
        <th>Organization</th>
        <th>Phone</th>
      </tr>
    </thead>
    <tbody>
      {entries.length === 0 && (
        <tr>
          <td colspan="6" style="text-align: center; padding: 32px; color: #64748b;">No leads found yet.</td>
        </tr>
      )}
      {entries.map((entry) => (
        <tr>
          <td>#{entry.id}</td>
          <td>{new Date(entry.createdAt).toLocaleString()}</td>
          <td style="font-weight: 600;">{entry.name}</td>
          <td><a href={`mailto:${entry.email}`} style="color: #4186f3; text-decoration: none;">{entry.email}</a></td>
          <td>{entry.company}</td>
          <td>{entry.role || '-'}</td>
        </tr>
      ))}
    </tbody>
  </table>
</body>
</html>
